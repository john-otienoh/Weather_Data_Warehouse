POSTGRES_DB=weather_db
POSTGRES_USER=weather_admin
POSTGRES_PASSWORD=change_me_to_something_strong
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://weather_admin:change_me_to_something_strong@localhost:5432/weather_db
 
# ── Airflow ────────────────────────────────────────────────────────────────────
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_generated_fernet_key_here
# Generate secret:    python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=your_generated_secret_key_here
AIRFLOW_ADMIN_PASSWORD=admin_password_here
AIRFLOW_ADMIN_EMAIL=you@example.com